# ─────────────────────────────────────────────────────────────────────────────
# Frontend (Vite) — copy to .env and fill in.
# ─────────────────────────────────────────────────────────────────────────────
VITE_INSFORGE_URL=https://your-app.us-east.insforge.app
VITE_INSFORGE_ANON_KEY=your_anon_key

# ─────────────────────────────────────────────────────────────────────────────
# Backend edge function secrets — NOT loaded from .env at runtime.
# Set these on the InsForge platform:
#   npx --yes @insforge/cli secrets add <KEY> <VALUE>
#
# (Reserved secrets like ANON_KEY, API_KEY, INSFORGE_BASE_URL,
# INSFORGE_INTERNAL_URL, JWT_SECRET are auto-injected by the platform — you
# do NOT need to set them.)
# ─────────────────────────────────────────────────────────────────────────────

# Alpaca Markets — historical bars, option chains, market calendar
# https://alpaca.markets/  → Paper or Live → API keys
ALPACA_API_KEY=
ALPACA_API_SECRET=

# Finnhub — fundamentals (market cap, P/E) and earnings dates
# https://finnhub.io/  → Dashboard → API key
FINNHUB_API_KEY=

# OpenRouter — LLM gateway for the trading-tick agent
# https://openrouter.ai/  → Keys
OPENROUTER_API_KEY=

# Shared secret used to authenticate scheduled invocations of edge functions.
# Generate any high-entropy string (e.g. `openssl rand -hex 32`) and add it
# both here and as the `X-Schedule-Secret` header on each schedule.
SCHEDULE_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Daily news scraper (Modal) — OPTIONAL, runs off-platform.
# Not set here. The Modal job reads its own secret (INSFORGE_BASE_URL,
# INSFORGE_API_KEY, FINNHUB_API_KEY, SCHEDULE_SECRET) created via
# `modal secret create gold-butterfly ...`. See modal/README.md.
# ─────────────────────────────────────────────────────────────────────────────
